# Postgres (required)
PG_HOST=localhost
PG_PORT=5432
PG_DB=claude_chats
PG_USER=postgres
PG_PASSWORD=postgres

# LLM + embeddings (optional, but required for Project Memory)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# LLM_PROVIDER=
# LLM_SUMMARY=off
# LLM_TIMEOUT_MS=15000

# Server / sync
# SYNC_INTERVAL_MINUTES=60

# SessionStart hook
# MEMORY_SERVER_URL=http://localhost:3737

# Backups (optional)
# BACKUP_S3_BUCKET=
